{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"]
  },
  "include": [
    "shared/**/*.ts",
    "shared/**/*.tsx",
    "services/**/*.ts",
    "services/**/*.tsx",
    "scripts/**/*.ts"
  ],
  "exclude": ["node_modules", "**/dist/**"]
}
